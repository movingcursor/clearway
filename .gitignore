# Live state — generated by render.py, gitignored to keep the repo
# free of household-specific data. Drop these in by hand on a fresh
# clone, or copy them from a trusted backup.
singbox-profiles/profiles.yaml
singbox-profiles/.secrets.yaml
singbox-profiles/.pending-rotations.yaml
singbox-profiles/secrets.txt
singbox-profiles/srv/
singbox-profiles/home_wg/*.conf
singbox-profiles/home_wg/*.conf.bak-*

# Server-side mutable state — populated by docker / rotate-hy2-cert.sh.
singbox-server/config.json
singbox-server/config.json.prev
singbox-server/hy2.crt
singbox-server/hy2.key
singbox-server/hy2.crt.bak-*
singbox-server/hy2.key.bak-*
singbox-server/.env

# awg-server config — rendered from .secrets.yaml's awg block. Carries the
# server private key inline (wg-quick format), so it must never enter the
# public repo. Path is created on first AWG-enabled render.
awg-server/config/*.conf
awg-server/config/*.conf.prev

# Backups created by the rotation scripts.
singbox-profiles/.secrets.yaml.bak-*
singbox-profiles/profiles.yaml.bak-*

# Repo-level overrides (PROFILE_HOST, VNIC_SECONDARY_IP, PUID/PGID).
.env
.env.local

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
