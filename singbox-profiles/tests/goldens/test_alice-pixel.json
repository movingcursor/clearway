{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "ntp": {
    "enabled": true,
    "server": "pool.ntp.org",
    "server_port": 123,
    "interval": "30m"
  },
  "dns": {
    "independent_cache": true,
    "servers": [
      {
        "tag": "bootstrap_dns",
        "type": "udp",
        "server": "1.1.1.1",
        "server_port": 53,
        "detour": "➡️ Direct"
      },
      {
        "tag": "fakeip-server",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      },
      {
        "tag": "cloudflare_doh",
        "type": "https",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query",
        "detour": "🌍 Default"
      }
    ],
    "rules": [
      {
        "domain": [
          "vpnws.example.com"
        ],
        "server": "bootstrap_dns"
      },
      {
        "rule_set": [
          "hagezi-tif",
          "hagezi-adblock",
          "iran-malware",
          "iran-phishing",
          "iran-ads"
        ],
        "action": "reject"
      },
      {
        "domain": [
          "home.example.test"
        ],
        "server": "cloudflare_doh"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "fakeip-server"
      },
      {
        "server": "cloudflare_doh"
      }
    ]
  },
  "endpoints": [
    {
      "type": "wireguard",
      "tag": "🏠 Home",
      "detour": "🔀 Proxy",
      "mtu": 1280,
      "address": [
        "10.10.0.2/24"
      ],
      "private_key": "TEST_WG_PRIV_PIXEL=====================================",
      "peers": [
        {
          "address": "home.example.test",
          "port": 51820,
          "public_key": "TEST_WG_PEER_PUBLIC_KEY==================================",
          "allowed_ips": [
            "0.0.0.0/0",
            "::/0"
          ],
          "persistent_keepalive_interval": 25
        }
      ]
    }
  ],
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.16.0.1/30"
      ],
      "auto_route": true,
      "strict_route": true,
      "mtu": 1380,
      "stack": "mixed"
    }
  ],
  "outbounds": [
    {
      "tag": "➡️ Direct",
      "type": "direct",
      "udp_fragment": false
    },
    {
      "tag": "🇨🇳 CN",
      "type": "direct"
    },
    {
      "tag": "🇷🇺 RU",
      "type": "direct"
    },
    {
      "tag": "🇮🇷 IR",
      "type": "direct"
    },
    {
      "type": "vless",
      "tag": "🔐 Reality",
      "server": "198.51.100.10",
      "server_port": 443,
      "uuid": "00000000-0000-4000-8000-000000000101",
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "console.example.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "TEST_REALITY_PUBLIC_KEY_______________________",
          "short_id": 4467856773185
        }
      }
    },
    {
      "type": "vless",
      "tag": "☁️ WS-CDN",
      "server": "vpnws.example.com",
      "server_port": 443,
      "uuid": "00000000-0000-4000-8000-000000000001",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "vpnws.example.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "ech": {
          "enabled": true
        }
      },
      "transport": {
        "type": "ws",
        "path": "/ws",
        "headers": {
          "Host": "vpnws.example.com"
        }
      }
    },
    {
      "type": "shadowtls",
      "tag": "shadowtls-transport",
      "server": "198.51.100.10",
      "server_port": 8443,
      "version": 3,
      "password": "TEST_SHADOWTLS_PW_ALICE__",
      "tls": {
        "enabled": true,
        "server_name": "cloud.example.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      }
    },
    {
      "type": "shadowsocks",
      "tag": "👻 ShadowTLS",
      "server": "198.51.100.10",
      "server_port": 8443,
      "method": "2022-blake3-aes-256-gcm",
      "password": "TEST_SS_PSK_32B_BASE64_PADDING_TO_44_CHARS=:TEST_SS_USER_ALICE_32B_BASE64_PAD_CHRS======",
      "detour": "shadowtls-transport"
    },
    {
      "type": "hysteria2",
      "tag": "🚀 Hysteria2",
      "server": "198.51.100.10",
      "server_port": 443,
      "password": "TEST_HY2_PW_ALICE_____",
      "up_mbps": 30,
      "down_mbps": 200,
      "obfs": {
        "type": "salamander",
        "password": "TEST_SALAMANDER_16B="
      },
      "tls": {
        "enabled": true,
        "server_name": "cloud.example.com",
        "alpn": [
          "h3"
        ],
        "certificate": [
          "-----BEGIN CERTIFICATE-----",
          "TESTHY2CERTLINE0000000000000000000000000000000000000000000000==",
          "TESTHY2CERTLINE1111111111111111111111111111111111111111111111==",
          "TESTHY2CERTLINE2222222222222222222222222222222222222222222222==",
          "-----END CERTIFICATE-----"
        ]
      }
    },
    {
      "tag": "⚡ Fastest",
      "type": "urltest",
      "outbounds": [
        "🔐 Reality",
        "☁️ WS-CDN",
        "👻 ShadowTLS",
        "🚀 Hysteria2"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "10m",
      "tolerance": 150,
      "idle_timeout": "1h",
      "interrupt_exist_connections": true
    },
    {
      "tag": "🔀 Proxy",
      "type": "selector",
      "outbounds": [
        "⚡ Fastest",
        "🔐 Reality",
        "☁️ WS-CDN",
        "👻 ShadowTLS",
        "🚀 Hysteria2"
      ],
      "default": "⚡ Fastest"
    },
    {
      "tag": "🏠 Home Egress",
      "type": "selector",
      "outbounds": [
        "🏠 Home",
        "🔀 Proxy",
        "➡️ Direct"
      ],
      "default": "🏠 Home"
    },
    {
      "tag": "🌍 Default",
      "type": "selector",
      "outbounds": [
        "🔀 Proxy",
        "🏠 Home",
        "➡️ Direct"
      ],
      "default": "🔀 Proxy"
    },
    {
      "tag": "🔒 Trusted",
      "type": "selector",
      "outbounds": [
        "🔀 Proxy",
        "➡️ Direct"
      ],
      "default": "🔀 Proxy"
    },
    {
      "tag": "🚨 Restricted",
      "type": "selector",
      "outbounds": [
        "🌍 Default",
        "🇨🇳 CN",
        "🇷🇺 RU",
        "🇮🇷 IR"
      ],
      "default": "🌍 Default"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "cloudflare_doh",
    "final": "🌍 Default",
    "rule_set": [
      {
        "tag": "hagezi-tif",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/razaxq/dns-blocklists-sing-box@rule-set/hagezi-tif.srs",
        "download_detour": "🌍 Default",
        "update_interval": "6h"
      },
      {
        "tag": "hagezi-adblock",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/razaxq/dns-blocklists-sing-box@rule-set/hagezi-pro.srs",
        "download_detour": "🌍 Default",
        "update_interval": "12h"
      },
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/cn.srs",
        "download_detour": "🌍 Default",
        "update_interval": "7d"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/cn.srs",
        "download_detour": "🌍 Default",
        "update_interval": "7d"
      },
      {
        "tag": "gfwlist-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/gfw.srs",
        "download_detour": "🌍 Default",
        "update_interval": "7d"
      },
      {
        "tag": "geosite-ru",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/runetfreedom/russia-v2ray-rules-dat@release/sing-box/rule-set-geosite/geosite-category-ru.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "geoip-ru",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/runetfreedom/russia-v2ray-rules-dat@release/sing-box/rule-set-geoip/geoip-ru.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "ru-available-only-inside",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/runetfreedom/russia-v2ray-rules-dat@release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "geosite-ru-blocked",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/runetfreedom/russia-v2ray-rules-dat@release/sing-box/rule-set-geosite/geosite-ru-blocked.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "geosite-ir",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-ir.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "geoip-ir",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geoip-ir.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "iran-malware",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-malware.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "iran-phishing",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-phishing.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "iran-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/chocolate4u/Iran-sing-box-rules@rule-set/geosite-category-ads-all.srs",
        "download_detour": "🌍 Default",
        "update_interval": "1d"
      },
      {
        "tag": "geoip-it",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geoip@rule-set/geoip-it.srs",
        "download_detour": "🌍 Default",
        "update_interval": "7d"
      },
      {
        "tag": "geoip-fr",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geoip@rule-set/geoip-fr.srs",
        "download_detour": "🌍 Default",
        "update_interval": "7d"
      },
      {
        "tag": "geoip-gb",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geoip@rule-set/geoip-gb.srs",
        "download_detour": "🌍 Default",
        "update_interval": "7d"
      }
    ],
    "rules": [
      {
        "port": 53,
        "action": "hijack-dns"
      },
      {
        "inbound": "tun-in",
        "action": "sniff"
      },
      {
        "network": "udp",
        "port": 443,
        "action": "reject"
      },
      {
        "network": "tcp",
        "port": 853,
        "action": "reject"
      },
      {
        "ip_is_private": true,
        "outbound": "➡️ Direct"
      },
      {
        "domain_suffix": [
          "local",
          "lan"
        ],
        "outbound": "➡️ Direct"
      },
      {
        "port": 22,
        "outbound": "➡️ Direct"
      },
      {
        "domain_suffix": [
          "1password.com",
          "adobe.com",
          "apple.com",
          "icloud.com",
          "microsoft.com",
          "microsoftonline.com",
          "live.com",
          "office.com",
          "paypal.com",
          "chase.com"
        ],
        "outbound": "🔒 Trusted"
      },
      {
        "rule_set": [
          "geoip-it",
          "geoip-fr",
          "geoip-gb"
        ],
        "outbound": "🏠 Home Egress"
      },
      {
        "domain_suffix": [
          "it",
          "fr",
          "uk",
          "eu"
        ],
        "outbound": "🏠 Home Egress"
      },
      {
        "rule_set": [
          "gfwlist-cn",
          "geosite-ru-blocked"
        ],
        "outbound": "🌍 Default"
      },
      {
        "rule_set": [
          "geosite-cn",
          "geoip-cn"
        ],
        "outbound": "🚨 Restricted"
      },
      {
        "rule_set": [
          "ru-available-only-inside",
          "geoip-ru"
        ],
        "outbound": "🚨 Restricted"
      },
      {
        "rule_set": [
          "geosite-ir",
          "geoip-ir"
        ],
        "outbound": "🚨 Restricted"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "store_rdrc": true,
      "rdrc_timeout": "7d",
      "store_fakeip": true
    }
  }
}
